# SheetDB API Configuration
# Get your API ID from https://sheetdb.io/
# IMPORTANT: Only put the API ID, not the full URL
# Example: VITE_SHEETDB_API_ID=ts2p47xonheq0
VITE_SHEETDB_API_ID=your_sheetdb_api_id_here

# true = leer productos/pedidos/categorías de SheetDB al abrir la app
VITE_SHEETDB_AUTO_LOAD=true

# Nombre de pestaña de productos en Google Sheets (vacío = hoja principal)
# VITE_SHEETDB_PRODUCTS_SHEET=products

# Pestañas que ya existen en el Sheet (evita errores 404 si no las tienes)
# VITE_SHEETDB_EXTRA_SHEETS=orders,config,categories

# Optional: Custom SheetDB API URL (if not using default)
# VITE_SHEETDB_API_URL=https://sheetdb.io/api/v1

# Deployment Version
# 'full' = versión completa (local) con Comparar y botón Comprar
# 'limited' = versión limitada (Vercel) sin Comparar y sin botón Comprar
VITE_DEPLOY_VERSION=full
